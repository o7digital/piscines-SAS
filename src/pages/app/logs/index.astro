---
import LogsTable from "../../../components/app/LogsTable";
import { logs, pools, properties } from "../../../data/mock";
import AppLayout from "../../../layouts/AppLayout.astro";
---
<AppLayout title="Logs" description="Daily check logs">
  <section class="space-y-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.2em] text-white/45">Compliance logbook</p>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight text-white md:text-4xl">Logs</h1>
        <p class="mt-3 text-white/70">
          Review all recorded water tests and operational checks. Saved demo entries persist in this browser
          after refresh.
        </p>
      </div>

      <a
        href="/app/logs/new"
        class="inline-flex items-center justify-center rounded-2xl bg-emerald-400 px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-emerald-300"
      >
        New daily check
      </a>
    </div>

    <LogsTable client:load properties={properties} pools={pools} initialLogs={logs} />
  </section>
</AppLayout>
