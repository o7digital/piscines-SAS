---
import NewLogForm from "../../../components/app/NewLogForm";
import { pools, properties } from "../../../data/mock";
import AppLayout from "../../../layouts/AppLayout.astro";
---
<AppLayout title="New Daily Check" description="Create a new daily pool check">
  <section class="mx-auto max-w-5xl space-y-6">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.2em] text-white/45">Operations input</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-white md:text-4xl">New daily check</h1>
      <p class="mt-3 text-white/70">
        Capture chemistry readings, note any follow-up actions, and confirm core operations items before the
        next shift starts.
      </p>
    </div>

    <NewLogForm client:load properties={properties} pools={pools} />
  </section>
</AppLayout>
