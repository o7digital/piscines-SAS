---
import DashboardOverview from "../../components/app/DashboardOverview";
import { alerts, logs, pools, properties } from "../../data/mock";
import AppLayout from "../../layouts/AppLayout.astro";
---
<AppLayout title="Dashboard" description="Bluu dashboard">
  <section class="space-y-6">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.2em] text-white/45">Operations overview</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-white md:text-4xl">Dashboard</h1>
      <p class="mt-3 text-white/70">
        Track chemistry, operations, and report readiness across the portfolio. New checks saved from this
        browser appear immediately in the activity feed below.
      </p>
    </div>

    <DashboardOverview client:load properties={properties} pools={pools} alerts={alerts} initialLogs={logs} />
  </section>
</AppLayout>
