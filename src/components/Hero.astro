---
const brand = "Bluu";
---
<section class="heroWrap">
  <div class="container heroGrid">
    <div class="card" style="padding:22px;">
      <div class="badge">⚙️ Operations + Standards • 🇺🇸 USA • 🇨🇦 Canada • 🇫🇷 France</div>
      <div style="height:14px;"></div>
      <h1 class="h1">
        Monitor pool operations, water quality & standards — with audit-ready logs.
      </h1>
      <p class="p" style="margin-top:12px;">
        {brand} is a SaaS platform for luxury properties and property managers: daily checks, maintenance logs,
        alerts, and monthly standards reports — designed to improve consistency and traceability.
      </p>

      <div class="kpi">
        <div class="pill">✅ Water tests tracking</div>
        <div class="pill">✅ Maintenance scheduling</div>
        <div class="pill">✅ Operations status check</div>
        <div class="pill">✅ PDF reporting</div>
      </div>

      <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:18px;">
        <a class="btn btnPrimary" href="#demo">Request a demo</a>
        <a class="btn" href="#pricing">See pricing</a>
        <a class="btn" href="#how">How it works</a>
      </div>

      <div class="hr"></div>

      <div class="small">
        Disclaimer: Bluu supports monitoring & documentation. It does not replace onsite teams,
        lifeguards, or operating procedures.
      </div>
    </div>

    <div class="card2" style="padding:22px; display:flex; flex-direction:column; gap:14px;">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
        <div>
          <div class="small">Live view (MVP)</div>
          <div style="font-weight:700; font-size:18px; margin-top:4px;">Portfolio Risk Snapshot</div>
        </div>
        <div class="badge">Beta</div>
      </div>

      <div class="card" style="padding:14px;">
        <div class="small">Villa • Miami</div>
        <div style="display:flex; justify-content:space-between; margin-top:8px;">
          <div>Water Quality</div><div>🟠 Attention</div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:8px;">
          <div>Operations Status</div><div>⚠️ Cover open</div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:8px;">
          <div>Last Check</div><div>Today 09:12</div>
        </div>
      </div>

      <div class="card" style="padding:14px;">
        <div class="small">Boutique Hotel • Nice</div>
        <div style="display:flex; justify-content:space-between; margin-top:8px;">
          <div>Water Quality</div><div>🟢 OK</div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:8px;">
          <div>Maintenance</div><div>✅ Scheduled</div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:8px;">
          <div>Monthly Report</div><div>Ready</div>
        </div>
      </div>

      <div class="small">
        This mock preview helps explain the product to investors. The app MVP starts with manual inputs + audit logs,
        then upgrades to automation later.
      </div>
    </div>
  </div>
</section>
